{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://proactive-ai-platform/contracts/PullRequestProposal.schema.json",
  "title": "PullRequestProposal",
  "description": "dev-auto 領域的對外/跨域輸出契約。PR 在合併到 main 前一律為 proposal（待人核准）。",
  "type": "object",
  "additionalProperties": false,
  "required": ["repo", "branch", "title", "rationale", "diff_summary", "test_result", "autonomy_gate"],
  "properties": {
    "repo": { "type": "string", "pattern": "^[^/]+/[^/]+$", "description": "owner/repo" },
    "base_branch": { "type": "string", "default": "main" },
    "branch": { "type": "string", "minLength": 1 },
    "title": { "type": "string", "minLength": 1 },
    "rationale": { "type": "string", "description": "為何這樣改（給審查者）" },
    "linked": {
      "type": "object",
      "description": "選填：來源關聯（如由 sec-ir 轉來的漏洞修補）",
      "additionalProperties": false,
      "properties": {
        "incident_id": { "type": "string" },
        "cve": { "type": "string", "pattern": "^CVE-[0-9]{4}-[0-9]+$" },
        "issue": { "type": "string" }
      }
    },
    "diff_summary": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["path", "change"],
        "properties": {
          "path": { "type": "string" },
          "change": { "enum": ["added", "modified", "deleted"] },
          "hunks": { "type": "integer", "minimum": 0 }
        }
      }
    },
    "test_result": {
      "type": "object",
      "additionalProperties": false,
      "required": ["ran_in_sandbox", "passed"],
      "properties": {
        "ran_in_sandbox": { "type": "boolean", "const": true, "description": "必須在隔離沙盒跑過" },
        "passed": { "type": "boolean" },
        "total": { "type": "integer", "minimum": 0 },
        "failed": { "type": "integer", "minimum": 0 },
        "reflection_iterations": { "type": "integer", "minimum": 0, "maximum": 3 }
      }
    },
    "autonomy_gate": {
      "type": "object",
      "additionalProperties": false,
      "required": ["state"],
      "properties": {
        "state": { "enum": ["drafted", "awaiting_approval", "approved", "merged", "rejected"] },
        "requires_human": { "type": "boolean", "description": "合併到 main 恆為 true" }
      }
    }
  }
}
