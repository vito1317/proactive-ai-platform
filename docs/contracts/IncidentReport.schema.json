{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://proactive-ai-platform/contracts/IncidentReport.schema.json",
  "title": "IncidentReport",
  "description": "sec-ir 領域的對外/跨域輸出契約。智能體間與 A2A handoff 一律照此傳遞。",
  "type": "object",
  "additionalProperties": false,
  "required": ["incident_id", "severity", "status", "summary", "timeline", "affected_assets", "recommended_actions"],
  "properties": {
    "incident_id": { "type": "string", "pattern": "^INC-[0-9]+$" },
    "severity": { "enum": ["P1", "P2", "P3", "P4"] },
    "status": { "enum": ["triaged", "investigating", "contained", "resolved", "false_positive"] },
    "summary": { "type": "string", "minLength": 1 },
    "attack_chain": {
      "type": "array",
      "description": "對照 MITRE ATT&CK 的技術鏈",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["technique_id", "name"],
        "properties": {
          "technique_id": { "type": "string", "pattern": "^T[0-9]{4}(\\.[0-9]{3})?$" },
          "name": { "type": "string" }
        }
      }
    },
    "timeline": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["at", "event"],
        "properties": {
          "at": { "type": "string", "format": "date-time" },
          "event": { "type": "string" },
          "actor": { "enum": ["agent", "human", "system"] }
        }
      }
    },
    "affected_assets": {
      "type": "array",
      "items": { "type": "string" }
    },
    "recommended_actions": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["action", "risk", "status"],
        "properties": {
          "action": { "type": "string" },
          "risk": { "enum": ["low", "medium", "high"] },
          "status": { "enum": ["proposed", "awaiting_approval", "approved", "executed", "rejected"] }
        }
      }
    },
    "handoff": {
      "type": "object",
      "description": "選填：需轉交其它領域時的 A2A artifact（如轉 dev-auto 修補漏洞）",
      "additionalProperties": false,
      "properties": {
        "to": { "type": "string" },
        "task": { "type": "string" },
        "artifact": { "type": "object" }
      }
    }
  }
}
